# =============================================================================
# Plantilla de variables de entorno (DevSecOps: secretos fuera del repositorio)
# =============================================================================
# Copia este archivo a `.env` y rellena los valores. El archivo `.env` está en
# .gitignore y NUNCA debe subirse al repositorio.

# URL del nodo RPC para la testnet Sepolia (ej: Alchemy, Infura).
SEPOLIA_RPC_URL=

# Clave privada de la cuenta de despliegue (¡SOLO una cuenta de pruebas!).
# Nunca uses aquí una clave con fondos reales.
PRIVATE_KEY=

# Activar el reporte de gas en las pruebas (true/false).
REPORT_GAS=false
